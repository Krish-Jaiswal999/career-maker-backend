# Database Configuration
DATABASE_URL=postgresql://career_user:secure-password@postgres:5432/career_maker_db

# JWT Configuration
SECRET_KEY=your-super-secret-key-min-32-chars-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Email Configuration (Gmail App Password)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SENDER_EMAIL=your-email@gmail.com
SENDER_PASSWORD=your-gmail-app-password

# Redis Configuration
REDIS_URL=redis://:secure-password@redis:6379

# OpenAI API (if using AI features)
OPENAI_API_KEY=sk-your-key-here

# LinkedIn (if using LinkedIn scraping)
LINKEDIN_EMAIL=your-email@example.com
LINKEDIN_PASSWORD=your-password

# Environment Settings
ENVIRONMENT=production
DEBUG=False

# CORS Configuration
ALLOWED_ORIGINS=["https://yourdomain.com", "https://www.yourdomain.com"]

# Logging
LOG_LEVEL=info

# Database Connection Pool
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
